# OpenAI (required for agent queries)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4.1-mini

# API server
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=*

# ClinicalTrials.gov client
CLINICAL_TRIALS_BASE_URL=https://clinicaltrials.gov/api/v2
CLINICAL_TRIALS_TIMEOUT=30
CLINICAL_TRIALS_MAX_PAGE_SIZE=200
CLINICAL_TRIALS_SCAN_PAGE_SIZE=1000
CLINICAL_TRIALS_USER_AGENT=clinical-trial-visualization-agent/0.1

# Agent limits — lower values reduce OpenAI TPM usage
AGGREGATION_TOP_N=15
AGGREGATION_TOP_N_MIN=5
AGGREGATION_TOP_N_MAX=100
AGENT_TOOL_MAX_TRIALS=10
AGENT_TOOL_MAX_TITLE_CHARS=120
AGENT_TOOL_MAX_CONDITIONS=2
CHART_PIE_MAX_BUCKETS=6
CHAT_CONTEXT_MAX_MESSAGES=6

# App
ENVIRONMENT=development
LOG_LEVEL=INFO
VENV_DIR=.venv
